void current_frequency() {
  digitalWrite(S2, HIGH);  //clear, no filter
  digitalWrite(S3, LOW);
  digitalWrite(S0, HIGH);  // Frequency scaling to 20%
  digitalWrite(S1, LOW);


  frequency = pulseIn(out, HIGH);


  Serial.println("Freq: ");
  Serial.println(frequency);
}

void detect_black_line() {
  if (!detect) return;

  digitalWrite(S2, HIGH);  //clear, no filter
  digitalWrite(S3, LOW);
  digitalWrite(S0, HIGH);  // Frequency scaling to 20%
  digitalWrite(S1, LOW);
  frequency = pulseIn(out, HIGH);
  black_line = (frequency >= black_value);



  /*if(frequency > black_value){
    dbug("Black Line Detected");
    // Add motor control code here
  } else {
    dbug("White Surface");
  }*/


  if (!black_line) {
    last_off_value = frequency;
    if (!off_value_printed) {
      Serial.print("last off line value:");
      Serial.println(last_off_value);
      off_value_printed = true;
    }
  }


  if (black_line && !last_state) {  // Print black value once when first hitting the black line
    Serial.println("black line");
    Serial.print("frequency: ");
    Serial.println(frequency);
    off_value_printed = false;
  }



  last_state = black_line;
}

void move_until_balck_line(int mode) {
  StepMode(mode);
  detect_black_line();


  if (!black_line) {
    if (r_dl() == 0) rMotor.move(10000);

    if (l_dl() == 0) lMotor.move(-10000);
    rMotor.run();
    lMotor.run();

  } else {

    rMotor.stop();
    lMotor.stop();


    Serial.println("stop");
  }
}

// ################################################### targetDistance
void targetDistance(float distance_mm, int speed, int accel, int turn) {  //0 straight, 1 rt, -1 lt
  lMotor.setMaxSpeed(speed);                                           //r steps per sec
  rMotor.setMaxSpeed(speed);


  lMotor.setAcceleration(accel);  //steps per sec
  rMotor.setAcceleration(accel);


  int steps = stepsForDistance(distance_mm);
  long rSteps = 0;
  long lSteps = 0;
//right wheel positive = forwards
//left wheel negative = forwards
  switch (turn) {
    case 0:
      rSteps = -steps;
      lSteps = -steps;
      break;
    case 1:  //left
      rSteps = steps;
      lSteps = -steps;
      break;
    case -1:
      rSteps = -steps;
      lSteps = steps;
      break;
  }
  
  rMotor.move(rSteps);  //move relative
  lMotor.move(lSteps);
  //N.B. distance, speed, maxSpeed and acceleration affect one another



  // rMotor.move(steps);
  // lMotor.move(-steps);

  //lMotor.setSpeed(speed); //use with runSpeed() steps /sec
}
//void turn(float distance,int speed)
void targetSteps(long steps, int speed, int accel, int turn) {
  lMotor.setMaxSpeed(speed);
  rMotor.setMaxSpeed(speed);
  lMotor.setAcceleration(accel);
  rMotor.setAcceleration(accel);

  long rSteps = 0;
  long lSteps = 0;

  switch (turn) {
    case 0:
      rSteps = -steps;
      lSteps = -steps;
      break;
    case 1:
      rSteps = steps;
      lSteps = -steps;
      break;
    case -1:
      rSteps = -steps;
      lSteps = steps;
      break;
  }

  rMotor.move(rSteps);
  lMotor.move(lSteps);
}

void turn(int DEGREE) {
  // OLD (buggy): integer division makes DEGREE/360 == 0 for <360
