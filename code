void loop() {
 bool currentButtonState = digitalRead(buttonPin);

 if (currentButtonState == HIGH && lastButtonState == LOW) {
    dbug(String(currentButtonState));
    run = !run;
    delay(500);

  }
  
  lastButtonState = currentButtonState;

  
  if (run){
    
    switch (currentTask){
      case 1:
        Serial.println((String(millis())));
        dbug("case 1");
        rMotor.enableOutputs();
        lMotor.enableOutputs();
        StepMode(1);
        
        lMotor.setCurrentPosition(0);
        rMotor.setCurrentPosition(0);

        targetDistance(1200, 200, 0);
        
        dbug("start");   
        digitalWrite(lEnable,LOW);
        digitalWrite(rEnable,LOW);
        while ((l_dl() != 0) || (r_dl() != 0)){
        
          if (abs(l_dl())>=0)lMotor.run();
          if (abs(r_dl())>=0)rMotor.run();
          
          String str1="!";
          str1= String(r_dl())+" "+String(rMotor.speed())+" "+String(millis()); // maxSpeed is ~1400
          dbug(str1);
        }
        delay(500);
        
        digitalWrite(lEnable,HIGH);
        digitalWrite(rEnable,HIGH);
        currentTask=2;   
        Serial.println((String(millis())));
        break;   
      case 2:
        //dbug("case 2");
        
       
        currentTask = 3;
        //Serial.println(l_dl());
        break;
        

        
        
      case 3:

        digitalWrite(lEnable, LOW);   
        digitalWrite(rEnable, LOW);   
        rMotor.enableOutputs();        
        lMotor.enableOutputs(); 
        detect_black_line();
        
        
        if(!black_line){
          if (r_dl() == 0) rMotor.move(10000);  
          
          if (l_dl() == 0) lMotor.move(10000);
          rMotor.run();
          lMotor.run();
          
        } else {

          rMotor.stop();
          lMotor.stop();
          rMotor.setCurrentPosition(rMotor.currentPosition());
          lMotor.setCurrentPosition(lMotor.currentPosition());

          Serial.println("stop");
          currentTask =4;
          


        }

        break;

      }
   
    
    }else{
    //whatever else  needs to stop
    lMotor.stop();
    rMotor.stop();
  }  

}




