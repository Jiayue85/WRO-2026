//calculates the steps needed for the turn
float stepsForTurning(float degree){
  Serial.println((float) (((TRACK_WIDTH * (degree/360))/WHEEL_DIAMETER) * STEPS_PER_REV ));
  return (float) (((TRACK_WIDTH  * (degree/360))/WHEEL_DIAMETER) * STEPS_PER_REV );
}

// Calculate steps for movements
int stepsForDistance(float distance) {//mm
  return (float)((distance/ (WHEEL_CIRCUMFERENCE)) * STEPS_PER_REV);
}


