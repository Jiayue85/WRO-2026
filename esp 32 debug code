// ========================================================
// Utility functions
// ========================================================

String formatTimestamp(uint32_t milliseconds)
{
  uint32_t totalSeconds = milliseconds / 1000;

  uint32_t hours = totalSeconds / 3600;
  uint32_t minutes = (totalSeconds % 3600) / 60;
  uint32_t seconds = totalSeconds % 60;

  char result[20];

  snprintf(
    result,
    sizeof(result),
    "%02lu:%02lu:%02lu",
    static_cast<unsigned long>(hours),
    static_cast<unsigned long>(minutes),
    static_cast<unsigned long>(seconds)
  );

  return String(result);
}

String escapeJson(const String& input)
{
  String output;
  output.reserve(input.length() + 10);

  for (size_t i = 0; i < input.length(); i++)
  {
    char character = input.charAt(i);

    switch (character)
    {
      case '"':
        output += "\\\"";
        break;

      case '\\':
        output += "\\\\";
        break;

      case '\n':
        output += "\\n";
        break;

      case '\r':
        output += "\\r";
        break;

      case '\t':
        output += "\\t";
        break;

      default:
        if (static_cast<uint8_t>(character) >= 32)
        {
          output += character;
        }
        break;
    }
  }

  return output;
}

// ========================================================
// Log management
// ========================================================

void addLog(String message)
{
  message.trim();

  if (message.length() == 0)
  {
    return;
  }

  uint8_t position;

  if (logCount < MAX_LOGS)
  {
    position = (logStart + logCount) % MAX_LOGS;
    logCount++;
  }
  else
  {
    position = logStart;
    logStart = (logStart + 1) % MAX_LOGS;
  }

  logs[position].id = nextLogId++;
  logs[position].timestamp = millis();
  logs[position].message = message;

  // Also show received messages in the ESP32 Serial Monitor.
  Serial.print("[MEGA] ");
  Serial.println(message);
}

void clearLogs()
{
  for (uint8_t i = 0; i < MAX_LOGS; i++)
  {
    logs[i].message = "";
  }

  logStart = 0;
  logCount = 0;
}

// ========================================================
// Serial receiver
// ========================================================

void readMegaSerial()
{
  while (MegaSerial.available() > 0)
  {
    char character = MegaSerial.read();

    if (character == '\n')
    {
      addLog(incomingMessage);
      incomingMessage = "";
    }
    else if (character != '\r')
    {
      if (incomingMessage.length() < MAX_MESSAGE_LENGTH)
      {
        incomingMessage += character;
      }
    }
  }
}

// ========================================================
// Web request handlers
// ========================================================

void handleHomepage()
{
  server.send_P(200, "text/html", INDEX_HTML);
}

void handleLogs()
{
  String json;
  json.reserve(24000);

  json = "[";

  for (uint8_t i = 0; i < logCount; i++)
  {
    uint8_t position = (logStart + i) % MAX_LOGS;

    if (i > 0)
    {
      json += ",";
    }

    json += "{\"id\":";
    json += String(logs[position].id);

    json += ",\"time\":\"";
    json += formatTimestamp(logs[position].timestamp);

    json += "\",\"message\":\"";
    json += escapeJson(logs[position].message);

    json += "\"}";
  }

  json += "]";

  server.sendHeader("Cache-Control", "no-store");
  server.send(200, "application/json", json);
}

void handleClear()
{
  clearLogs();
  addLog("INFO: Debug log cleared");

  server.send(
    200,
    "application/json",
    "{\"success\":true}"
  );
}

// ========================================================
// Setup
// ========================================================

void setup()
{
  Serial.begin(115200);

  MegaSerial.begin(
    DEBUG_BAUD,
    SERIAL_8N1,
    MEGA_RX_PIN,
    MEGA_TX_PIN
  );

  incomingMessage.reserve(MAX_MESSAGE_LENGTH);

  WiFi.mode(WIFI_AP);

  bool accessPointStarted = WiFi.softAP(
    AP_SSID,
    AP_PASSWORD
  );

  if (!accessPointStarted)
  {
    Serial.println("Failed to start Wi-Fi access point.");
  }

  server.on("/", HTTP_GET, handleHomepage);
  server.on("/api/logs", HTTP_GET, handleLogs);
  server.on("/api/clear", HTTP_POST, handleClear);

  server.onNotFound([]()
  {
    server.send(404, "text/plain", "Page not found");
  });

  server.begin();

  IPAddress address = WiFi.softAPIP();

  Serial.println();
  Serial.println("ESP32 debug dashboard started");
  Serial.print("Wi-Fi network: ");
  Serial.println(AP_SSID);
  Serial.print("Dashboard address: http://");
  Serial.println(address);

  addLog("OK: ESP32 debug dashboard started");
  addLog("INFO: Waiting for Arduino Mega messages");
}

// ========================================================
// Main loop
// ========================================================

void loop()
{
  readMegaSerial();
  server.handleClient();

  delay(1);
}
