// ################################################### targetDistance
void targetDistance(float distance_mm, int speed, int accel, int turn) { // 0 straight, 1 left, -1 right
  lMotor.setMaxSpeed(speed);
  rMotor.setMaxSpeed(speed);
  lMotor.setAcceleration(accel);
  rMotor.setAcceleration(accel);

  const long steps = stepsForDistance(distance_mm);
  long rSteps = 0;
  long lSteps = 0;

  switch (turn) {
    case 0:
      rSteps = steps;
      lSteps = steps;
      break;
    case 1:
      rSteps = -steps;
      lSteps = steps;
      break;
    case -1:
      rSteps = steps;
      lSteps = -steps;
      break;
  }

  debugLog(String(F("MOVE: distance=")) + String(distance_mm, 1) +
           F(" mm, steps=") + String(steps) +
           F(", speed=") + String(speed) +
           F(", accel=") + String(accel) +
           F(", mode=") + String(turn));

  rMotor.move(rSteps);
  lMotor.move(lSteps);

  if (turn == 0) {
    beginHeadingHold(distance_mm, steps, speed);
  } else {
    stopHeadingHold();
  }
}
//void turn(float distance,int speed)
void targetSteps(long steps, int speed, int accel, int turn) {
  stopHeadingHold();
  updateMPU6050();

  lMotor.setMaxSpeed(speed);
  rMotor.setMaxSpeed(speed);
  lMotor.setAcceleration(accel);
  rMotor.setAcceleration(accel);

  long rSteps = 0;
  long lSteps = 0;
  switch (turn) {
    case 0:
      rSteps = steps;
      lSteps = steps;
      break;
    case 1:  //left
      rSteps = -steps;
      lSteps = steps;
      break;
    case -1:
      rSteps = steps;
      lSteps = -steps;
      break;
  }
 
  debugLog(String(F("MOVE_STEPS: steps=")) + String(steps) +
           F(", speed=") + String(speed) +
           F(", accel=") + String(accel) +
           F(", mode=") + String(turn));

  rMotor.move(rSteps);
  lMotor.move(lSteps);
}

void turn(int DEGREE) {  // positive = left, negative = right
  debugLog(String(F("TURN: degrees = ")) + String(DEGREE));

  int direction = (DEGREE < 0) ? 1 : -1;
  targetSteps(stepsForTurning(abs(DEGREE)), 500, 100, direction);
  // targetSteps(stepsForTurning(DEGREE), 500, 100, direction);
  //return 1
}

