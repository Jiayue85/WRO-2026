bool run_until_done() {
  while ((l_dl() != 0) || (r_dl() != 0)) {
    check_button();

    if (!run) {
      lMotor.stop();
      rMotor.stop();
      return false;
      break;
    }

    lMotor.run();
    rMotor.run();
  }
  return true;
}
