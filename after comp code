//calculates the steps needed for the turn
float stepsForTurning(float degree) {
  const float steps = ((TRACK_WIDTH * (degree / 360.0)) / WHEEL_DIAMETER) * STEPS_PER_REV;
  debugLog(String(F("CALC: turn steps = ")) + String(steps, 2));
  return steps;
}

// Calculate the nearest whole step count for a requested distance.
long stepsForDistance(float distance) { // mm
  return lround((distance / WHEEL_CIRCUMFERENCE) * STEPS_PER_REV);
}


