// ################################################### targetDistance
void targetDistance(float distance_mm, int speed, int accel, int turn) {  //0 straight, 1 rt, -1 lt
  lMotor.setMaxSpeed(speed);                                           //r steps per sec
  rMotor.setMaxSpeed(speed);


  lMotor.setAcceleration(accel);  //steps per sec
  rMotor.setAcceleration(accel);


  int steps = stepsForDistance(distance_mm);
  long rSteps = 0;
  long lSteps = 0;
//right wheel positive = forwards
//left wheel negative = forwards
  switch (turn) {
    case 0:
      rSteps = steps;
      lSteps = steps;
      break;
    case 1:  //left
      rSteps = -steps;
      lSteps = steps;
      break;
    case -1:
      rSteps = steps;
      lSteps = -steps;
      break;
  }
  
  rMotor.move(rSteps);  //move relative
  lMotor.move(lSteps);
  //N.B. distance, speed, maxSpeed and acceleration affect one another



  // rMotor.move(steps);
  // lMotor.move(-steps);

  //lMotor.setSpeed(speed); //use with runSpeed() steps /sec
}
//void turn(float distance,int speed)
void targetSteps(long steps, int speed, int accel, int turn) {
  lMotor.setMaxSpeed(speed);
  rMotor.setMaxSpeed(speed);
  lMotor.setAcceleration(accel);
  rMotor.setAcceleration(accel);

  long rSteps = 0;
  long lSteps = 0;
  switch (turn) {
    case 0:
      rSteps = steps;
      lSteps = steps;
      break;
    case 1:  //left
      rSteps = -steps;
      lSteps = steps;
      break;
    case -1:
      rSteps = steps;
      lSteps = -steps;
      break;
  }
 
  rMotor.move(rSteps);
  lMotor.move(lSteps);
}

void turn(int DEGREE) {// postive = left negative = right

  int direction = (DEGREE < 0) ? 1 : -1;
  targetSteps(stepsForTurning(abs(DEGREE)), 500, 100, direction);
  // targetSteps(stepsForTurning(DEGREE), 500, 100, direction);
  //return 1
}

void carteraige_servo(int angle){// servo write 90 is having the grid flat on the floor
  if (millis() - last_move > 50){
    last_move = millis();
     servo.write(angle);
  }
}


void back_servo(int angle){// servo write 90 is having the grid flat on the floor
  if (millis() - last_move > 50){
    last_move = millis();
     servo.write(angle);
  }
}



void setup() {

  servo.attach(servo_pin);

  Serial.begin(115200);
  lMotor.setEnablePin(lEnable);
  rMotor.setEnablePin(rEnable);


  delay(100);
  lMotor.setMaxSpeed(1100);  //r steps per sec
  rMotor.setMaxSpeed(1100);

  lMotor.setAcceleration(600);  //steps per sec
  rMotor.setAcceleration(600);


  
  Serial.println("setup");

  pinMode(buttonPin, INPUT_PULLUP);
  pinMode(lEnable, OUTPUT);
  pinMode(rEnable, OUTPUT);
  lMotor.setCurrentPosition(0);
  rMotor.setCurrentPosition(0);


  currentTask = 1;
  digitalWrite(lEnable, LOW);
  digitalWrite(rEnable, LOW);
  back_servo(140);
}
