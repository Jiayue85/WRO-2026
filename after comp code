  bool reading = digitalRead(buttonPin);

    if (reading == !lastButtonState) {
        lastDebounceTime = millis();
    }

    if ((millis() - lastDebounceTime) > debounceDelay) {

        if (reading == !currentState) {
            currentState = reading;

            if (currentState == LOW) {
                toggleState = !toggleState;
                run = toggleState;

                if (run) {
                  debugLog(F("OK: Robot resumed"));
                } else {
                  currentTask = 1;
                  stopHeadingHold();
                  lMotor.stop();
                  rMotor.stop();
                  lMotor.setCurrentPosition(0);
                  rMotor.setCurrentPosition(0);
                  debugLog(F("WARN: Robot stopped and task sequence reset"));
                }
            }
        }
    }

    lastButtonState = reading;
}


bool run_until_done() {
  while ((l_dl() != 0) || (r_dl() != 0)) {
    check_button();

    if (!run) {
      stopHeadingHold();
      lMotor.stop();
      rMotor.stop();
      return false;
    }

    if (headingHoldActive) {
      applyHeadingHold();
    } else {
      updateMPU6050();
    }

    lMotor.run();
    rMotor.run();
  }

  if (headingHoldActive) {
    updateMPU6050();
    const float finalError = wrappedAngleError(headingTargetDegrees, yawDegrees);
    debugLog(String(F("GYRO: straight move complete, final error=")) +
             String(finalError, 2) + F(" deg"));
  }

  stopHeadingHold();
  return true;
}
void finish_task(int nextTask) {
  cases = String(F("TASK: case "));
  casenum = cases + currentTask;

  dbug(casenum);
  
  if (run_until_done()) {
    currentTask = nextTask;
  }
}

