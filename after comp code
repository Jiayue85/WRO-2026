void setup() {

  servo.attach(servo_pin);

  Serial.begin(USB_BAUD);
  Serial3.begin(DEBUG_BAUD);

  lMotor.setEnablePin(lEnable);
  rMotor.setEnablePin(rEnable);


  delay(100);
  lMotor.setMaxSpeed(1100);  //r steps per sec
  rMotor.setMaxSpeed(1100);

  lMotor.setAcceleration(600);  //steps per sec
  rMotor.setAcceleration(600);


  
  debugLog(F("OK: Arduino Mega setup started"));

  pinMode(buttonPin, INPUT_PULLUP);
  pinMode(lEnable, OUTPUT);
  pinMode(rEnable, OUTPUT);
  lMotor.setCurrentPosition(0);
  rMotor.setCurrentPosition(0);


  currentTask = 1;
  digitalWrite(lEnable, LOW);
  digitalWrite(rEnable, LOW);
  back_servo(140);

  // RUMBA/Mega I2C uses SDA pin 20 and SCL pin 21.
  Wire.begin();
  Wire.setClock(400000UL);
  delay(500); // Let the robot and sensor become still before calibration.

  mpuReady = initialiseMPU6050();
  if (mpuReady) {
    mpuReady = calibrateMPU6050Gyro();
  }

  if (mpuReady) {
    debugLog(String(F("OK: MPU6050 ready at I2C address 0x")) + String(mpuAddress, HEX));
  } else {
    debugLog(F("ERROR: MPU6050 not available; gyro correction disabled"));
  }

  debugLog(F("OK: Robot initialised"));
  debugLog(F("INFO: Debug output is active on Serial3"));
}
