// -----------------------------------------------------------------------------
// MPU6050 low-level I2C and heading functions
// This uses Wire directly, so no extra MPU6050 library is required.
// -----------------------------------------------------------------------------
bool mpuWriteRegister(uint8_t reg, uint8_t value) {
  Wire.beginTransmission(mpuAddress);
  Wire.write(reg);
  Wire.write(value);
  return Wire.endTransmission() == 0;
}

bool mpuReadRegisters(uint8_t startReg, uint8_t* data, uint8_t length) {
  Wire.beginTransmission(mpuAddress);
  Wire.write(startReg);
  if (Wire.endTransmission(false) != 0) {
    return false;
  }

  const uint8_t received = Wire.requestFrom(mpuAddress, length);
  if (received != length) {
    while (Wire.available()) {
      Wire.read();
    }
    return false;
  }

  for (uint8_t i = 0; i < length; i++) {
    data[i] = Wire.read();
  }
  return true;
}

bool mpuAddressResponds(uint8_t address) {
  mpuAddress = address;
  uint8_t whoAmI = 0;
  if (!mpuReadRegisters(0x75, &whoAmI, 1)) {
    return false;
  }
  return whoAmI == 0x68 || whoAmI == 0x69;
}

bool initialiseMPU6050() {
  if (!mpuAddressResponds(0x68) && !mpuAddressResponds(0x69)) {
    return false;
  }

  // Wake sensor and use the X gyro PLL as its clock source.
  if (!mpuWriteRegister(0x6B, 0x01)) return false; // PWR_MGMT_1
  delay(100);

  // 1 kHz internal rate / (1 + 4) = 200 Hz sample rate.
  if (!mpuWriteRegister(0x19, 0x04)) return false; // SMPLRT_DIV
  if (!mpuWriteRegister(0x1A, 0x03)) return false; // CONFIG: DLPF about 44 Hz gyro
  if (!mpuWriteRegister(0x1B, 0x00)) return false; // GYRO_CONFIG: +/-250 dps
  if (!mpuWriteRegister(0x1C, 0x00)) return false; // ACCEL_CONFIG: +/-2 g

  lastMpuMicros = micros();
  return true;
}

bool readMPU6050Raw(int16_t& ax, int16_t& ay, int16_t& az,
                    int16_t& gx, int16_t& gy, int16_t& gz) {
  uint8_t data[14];
  if (!mpuReadRegisters(0x3B, data, sizeof(data))) {
    return false;
  }

  ax = (int16_t)((data[0] << 8) | data[1]);
  ay = (int16_t)((data[2] << 8) | data[3]);
  az = (int16_t)((data[4] << 8) | data[5]);
  gx = (int16_t)((data[8] << 8) | data[9]);
  gy = (int16_t)((data[10] << 8) | data[11]);
  gz = (int16_t)((data[12] << 8) | data[13]);
  return true;
}

bool calibrateMPU6050Gyro() {
  debugLog(F("INFO: Keep the robot completely still - calibrating MPU6050"));

  int16_t ax, ay, az, gx, gy, gz;
  long totalGz = 0;
  int validSamples = 0;

  // Discard initial samples after wake-up.
  for (int i = 0; i < 100; i++) {
    readMPU6050Raw(ax, ay, az, gx, gy, gz);
    delay(2);
  }

  constexpr int CALIBRATION_SAMPLES = 1200;
  for (int i = 0; i < CALIBRATION_SAMPLES; i++) {
    if (readMPU6050Raw(ax, ay, az, gx, gy, gz)) {
      totalGz += gz;
      validSamples++;
    }
    delay(2);
  }

  if (validSamples < CALIBRATION_SAMPLES / 2) {
    debugLog(F("ERROR: MPU6050 calibration failed"));
    return false;
  }

  gyroBiasRaw = (float)totalGz / (float)validSamples;
  gyroZRateDps = 0.0f;
  yawDegrees = 0.0f;
  lastMpuMicros = micros();

  debugLog(String(F("OK: MPU6050 calibrated, Z bias=")) + String(gyroBiasRaw, 2));
  return true;
}

void updateMPU6050() {
  if (!mpuReady) return;

  const unsigned long now = micros();
  const unsigned long elapsed = now - lastMpuMicros;
  if (elapsed < MPU_UPDATE_US) return;

  lastMpuMicros = now;
  float dt = elapsed * 0.000001f;
  if (dt <= 0.0f || dt > 0.1f) {
    return;
  }

  int16_t ax, ay, az, gx, gy, gz;
  if (!readMPU6050Raw(ax, ay, az, gx, gy, gz)) {
    return;
  }

  gyroZRateDps = ((float)gz - gyroBiasRaw) / GYRO_SCALE_250DPS;
  yawDegrees += gyroZRateDps * dt;

  const float axG = ax / 16384.0f;
  const float ayG = ay / 16384.0f;
  const float azG = az / 16384.0f;
  accelMagnitudeG = sqrt(axG * axG + ayG * ayG + azG * azG);

  // Slowly refine gyro bias only while the robot is genuinely stationary.
  if (!headingHoldActive && lMotor.distanceToGo() == 0 && rMotor.distanceToGo() == 0 &&
      fabs(gyroZRateDps) < 0.75f && accelMagnitudeG > 0.92f && accelMagnitudeG < 1.08f) {
    gyroBiasRaw = gyroBiasRaw * 0.9995f + (float)gz * 0.0005f;
  }
}

float wrappedAngleError(float target, float measured) {
  float error = target - measured;
  while (error > 180.0f) error -= 360.0f;
  while (error < -180.0f) error += 360.0f;
  return error;
}

void stopHeadingHold() {
  headingHoldActive = false;
}

void beginHeadingHold(float distanceMm, long targetSteps, int speed) {
  updateMPU6050();

  straightBaseSpeed = speed;
  straightTravelDirection = (targetSteps >= 0) ? 1 : -1;
  headingTargetDegrees = yawDegrees;
  lastHeadingDebugTime = 0;

  headingHoldActive = mpuReady && fabs(distanceMm) >= MIN_HOLD_DISTANCE_MM;

  if (headingHoldActive) {
    debugLog(String(F("GYRO: heading hold ON, target=")) +
             String(headingTargetDegrees, 2) + F(" deg"));
  } else if (!mpuReady) {
    debugLog(F("WARN: Straight move running without MPU6050 correction"));
  }
}

void applyHeadingHold() {
  updateMPU6050();
  if (!headingHoldActive) return;

  float error = wrappedAngleError(headingTargetDegrees, yawDegrees);
  if (fabs(error) < HEADING_DEADBAND_DEG) {
    error = 0.0f;
  }

  float correction = (HEADING_KP * error) - (HEADING_KD * gyroZRateDps);
  correction *= HEADING_CORRECTION_SIGN;

  const float proportionalLimit = straightBaseSpeed * 0.35f;
  const float correctionLimit = min(MAX_HEADING_CORRECTION, proportionalLimit);
  correction = constrain(correction, -correctionLimit, correctionLimit);

  // Reverse moves need the speed differential reversed to create the same yaw correction.
  const float wheelAdjustment = correction * straightTravelDirection;
  float rightMaxSpeed = straightBaseSpeed + wheelAdjustment;
  float leftMaxSpeed = straightBaseSpeed - wheelAdjustment;

  const float minimumAllowedSpeed = max(60.0f, straightBaseSpeed * 0.55f);
  rightMaxSpeed = constrain(rightMaxSpeed, minimumAllowedSpeed, 1100.0f);
  leftMaxSpeed = constrain(leftMaxSpeed, minimumAllowedSpeed, 1100.0f);

  rMotor.setMaxSpeed(rightMaxSpeed);
  lMotor.setMaxSpeed(leftMaxSpeed);

  if (millis() - lastHeadingDebugTime >= HEADING_DEBUG_MS) {
    lastHeadingDebugTime = millis();
    debugLog(String(F("GYRO: yaw=")) + String(yawDegrees, 2) +
             F(", error=") + String(error, 2) +
             F(", rate=") + String(gyroZRateDps, 2) +
             F(", Lmax=") + String(leftMaxSpeed, 0) +
             F(", Rmax=") + String(rightMaxSpeed, 0));
  }
}

void robotDelay(unsigned long durationMs) {
  const unsigned long start = millis();
  while (millis() - start < durationMs) {
    updateMPU6050();
    check_button();
    if (!run) return;
  }
}

bool pauseDone(unsigned long waitTime) {
  if (!waiting) {
    pauseStart = millis();
    waiting = true;
  }

  if (millis() - pauseStart >= waitTime) {
    waiting = false;
    return true;
  }

  return false;
}




